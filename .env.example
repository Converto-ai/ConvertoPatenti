# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Auth.js v5
AUTH_SECRET=<generate: openssl rand -base64 32>
AUTH_URL=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=<from @BotFather>
TELEGRAM_BOT_USERNAME=<bot username without @>
TELEGRAM_WEBHOOK_SECRET=<generate: openssl rand -hex 32>
TELEGRAM_LINK_SECRET=<generate: openssl rand -base64 32>

# Anthropic (AI Agent)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Blob (file storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Deploy (for webhook registration)
APP_URL=https://yourapp.vercel.app
